[user]
  name = Akshay Aurora
  email = akshayaurora@yahoo.com

[alias]
  co = checkout
  br = branch
  pu = "!f() { B=$(git rev-parse --abbrev-ref HEAD);git push origin \"$B:akshay/$B\"; }; f"
  puf = "!f() { B=$(git rev-parse --abbrev-ref HEAD);git push origin \"$B:akshay/$B\" --force; }; f"

[core]
  editor = vim
  pager = delta
  excludesfile = ~/.gitignore

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = true

[color]
  ui = true

[push]
	default = current

[diff]
  colorMoved = default

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[rebase]
	updateRefs = true
[maintenance]
	repo = /Users/akshayaurora/Projects/core
